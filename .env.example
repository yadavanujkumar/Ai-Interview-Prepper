# Environment variables for AI Interview Prepper
# Copy this file to .env and fill in your actual values

# Flask configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# OpenAI API configuration (optional - app will work without it using rule-based analysis)
OPENAI_API_KEY=your-openai-api-key-here

# Database configuration (for future use)
DATABASE_URL=sqlite:///interview_prepper.db

# Email configuration (for future use)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Redis configuration for rate limiting (for future use)
REDIS_URL=redis://localhost:6379/0